PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# PostgreSQL — run locally: createdb slidemind
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/slidemind"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=""

# Pexels — https://www.pexels.com/api
PEXELS_API_KEY=""

# Unsplash — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=""

# Resend — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="noreply@slidemind.uz"

# File uploads — local folder (no S3/R2 in Phase 1)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://back.slidemind.uz/api/v1/auth/google/callback"

# TSPay — https://tspay.uz
TSPAY_MERCHANT_ID=""
TSPAY_WEBHOOK_SECRET=""
